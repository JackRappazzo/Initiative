{
  "manifestVersion": 1,
  "name": "Initiative",
  "summary": "D&D combat tracker and encounter manager",
  "entryPoint": "http://localhost:3000",
  "api": {
    "version": "0.1",
    "initTimeout": 10,
    "subscriptions": {
      "chat": {
        "onChatMessage": "handleInitiativeChatMessage"
      }
    }
  },
  "controls": {
    "reload": true
  },
  "icons": {
    "64x64": "/icon.png"
  },
  "environment": {
    "extras": [
      "colorStyles",
      "/bridge.js"
    ]
  }
}
